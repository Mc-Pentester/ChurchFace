# Base de données PostgreSQL (Neon, Supabase, Railway...)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth — générer un secret fort : openssl rand -base64 32
NEXTAUTH_SECRET="change_me"
NEXTAUTH_URL="https://votre-domaine.com"

# JWT (endpoints /api/auth/token et /api/auth/refresh) — requis, générer : openssl rand -base64 32
JWT_SECRET="change_me"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS="30"

# Origines autorisées pour Socket.io (CORS), séparées par des virgules.
# Par défaut : NEXT_PUBLIC_APP_URL
SOCKET_CORS_ORIGINS="https://votre-domaine.com"

# URL publique de l'app (Socket.io + liens)
NEXT_PUBLIC_APP_URL="https://votre-domaine.com"

# UploadThing — https://uploadthing.com/dashboard
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
UPLOADTHING_TOKEN=""

# LiveKit — https://livekit.io/cloud
LIVEKIT_API_KEY="your_api_key"
LIVEKIT_API_SECRET="your_api_secret"
LIVEKIT_URL="wss://your-livekit-server.livekit.cloud"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-livekit-server.livekit.cloud"

# Serveurs STUN/TURN pour WebRTC (optionnel si LiveKit Cloud)
# LiveKit Cloud fournit des serveurs STUN/TURN par défaut
# Pour configuration personnalisée :
NEXT_PUBLIC_LIVEKIT_STUN_SERVERS="stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302"
NEXT_PUBLIC_LIVEKIT_TURN_SERVERS="turn:your-turn-server.com:3478?transport=udp"
NEXT_PUBLIC_LIVEKIT_TURN_USERNAME="your_turn_username"
NEXT_PUBLIC_LIVEKIT_TURN_CREDENTIAL="your_turn_credential"

# Optionnel
PORT=3000
HOSTNAME=0.0.0.0
