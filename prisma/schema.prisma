generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  password                String
  createdAt               DateTime                 @default(now())
  image                   String?
  name                    String?
  bio                     String?
  role                    String                   @default("USER")
  church                  String?
  city                    String?
  bannedAt                DateTime?
  isBanned                Boolean                  @default(false)
  isSuspended             Boolean                  @default(false)
  suspendedAt             DateTime?
  accounts                Account[]
  adminLogs               AdminLog[]
  chats                   ChatMember[]
  churchAdmins            ChurchAdmin[]
  churchCourseEnrollments ChurchCourseEnrollment[]
  churchEventAttendees    ChurchEventAttendee[]
  churchFollows           ChurchFollow[]
  churchMembers           ChurchMember[]
  churchPostComments      ChurchPostComment[]
  churchPostLikes         ChurchPostLike[]
  comments                Comment[]
  friendshipsReceived     Friendship[]             @relation("ReceivedFriendships")
  friendshipsSent         Friendship[]             @relation("SentFriendships")
  likes                   Like[]
  liveBroadcasts          LiveBroadcast[]          @relation("LiveBroadcasts")
  messages                Message[]
  messagesSeen            MessageSeen[]
  sentNotifications       Notification[]           @relation("Sender")
  notifications           Notification[]           @relation("Receiver")
  posts                   Post[]
  prayerChainLinks        PrayerChainLink[]
  prayerReactions         PrayerReaction[]
  prayerRequests          PrayerRequest[]
  prayerResponses         PrayerResponse[]
  prayerRoomParticipants  PrayerRoomParticipant[]
  prayerTestimonies       PrayerTestimony[]
  prayerVerses            PrayerVerse[]
  preachings              Preaching[]              @relation("Preachings")
  preachingBookmarks      PreachingBookmark[]      @relation("PreachingBookmarks")
  preachingComments       PreachingComment[]       @relation("PreachingComments")
  preachingLikes          PreachingLike[]          @relation("PreachingLikes")
  preachingNotes          PreachingNote[]          @relation("PreachingNotes")
  preachingSeries         PreachingSeries[]        @relation("PreachingSeries")
  preachingViews          PreachingView[]          @relation("PreachingViews")
  pushSubscriptions       PushSubscription[]
  radios                  Radio[]
  reports                 Report[]                 @relation("ReportedItems")
  sessions                Session[]
  shares                  Share[]
  stories                 Story[]
  storyViews              StoryView[]
  streams                 Stream[]
  followers               UserFollow[]             @relation("Followers")
  following               UserFollow[]             @relation("Following")
}

model Chat {
  id        String       @id @default(cuid())
  isGroup   Boolean      @default(false)
  name      String?
  createdAt DateTime     @default(now())
  members   ChatMember[]
  messages  Message[]
}

model ChatMember {
  id       String    @id @default(cuid())
  userId   String
  chatId   String
  isTyping Boolean   @default(false)
  lastSeen DateTime?
  chat     Chat      @relation(fields: [chatId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@unique([userId, chatId])
}

model Message {
  id        String        @id @default(cuid())
  content   String
  createdAt DateTime      @default(now())
  chatId    String
  senderId  String
  chat      Chat          @relation(fields: [chatId], references: [id])
  sender    User          @relation(fields: [senderId], references: [id])
  seenBy    MessageSeen[]
}

model MessageSeen {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  seenAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model Post {
  id        String    @id @default(cuid())
  content   String?
  createdAt DateTime  @default(now())
  authorId  String
  hashtags  String[]  @default([])
  imageUrl  String?
  videoUrl  String?
  isHidden  Boolean   @default(false)
  isPinned  Boolean   @default(false)
  comments  Comment[]
  likes     Like[]
  author    User      @relation(fields: [authorId], references: [id])
  shares    Share[]

  @@index([createdAt])
  @@index([authorId, createdAt])
  @@index([isHidden])
  @@index([isPinned])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model Share {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime  @default(now())
  parentId  String?
  isHidden  Boolean   @default(false)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  post      Post      @relation(fields: [postId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId])
  @@index([isHidden])
}

model Story {
  id        String      @id @default(cuid())
  imageUrl  String?
  videoUrl  String?
  content   String?
  createdAt DateTime    @default(now())
  expiresAt DateTime
  authorId  String
  isHidden  Boolean     @default(false)
  author    User        @relation(fields: [authorId], references: [id])
  views     StoryView[]

  @@index([expiresAt])
  @@index([authorId, createdAt])
  @@index([isHidden])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([storyId, userId])
}

model Notification {
  id         String   @id @default(cuid())
  type       String
  message    String
  isRead     Boolean  @default(false)
  userId     String
  createdAt  DateTime @default(now())
  senderId   String?
  data       Json?
  entityId   String?
  entityType String?
  sender     User?    @relation("Sender", fields: [senderId], references: [id])
  user       User     @relation("Receiver", fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  createdAt   DateTime @default(now())
}

model Stream {
  id          String    @id @default(cuid())
  title       String
  description String?
  isLive      Boolean   @default(true)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  viewerCount Int       @default(0)
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  @@index([isLive, startedAt])
  @@index([userId])
}

model Radio {
  id             String             @id @default(cuid())
  title          String
  description    String?
  isLive         Boolean            @default(false)
  isAutoDJ       Boolean            @default(false)
  startedAt      DateTime           @default(now())
  endedAt        DateTime?
  listenerCount  Int                @default(0)
  peakListeners  Int                @default(0)
  totalDuration  Int                @default(0)
  streamUrl      String?
  rtmpUrl        String?
  currentTrackId String?
  userId         String
  playlistId     String?
  playlist       Playlist?          @relation(fields: [playlistId], references: [id])
  user           User               @relation(fields: [userId], references: [id])
  chatMessages   RadioChatMessage[]
  schedules      RadioSchedule[]

  @@index([isLive, startedAt])
  @@index([userId])
}

model Playlist {
  id          String          @id @default(cuid())
  title       String
  description String?
  isAutoDJ    Boolean         @default(false)
  category    String          @default("GENERAL")
  isActive    Boolean         @default(true)
  shuffle     Boolean         @default(false)
  loop        Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  churchId    String?
  church      Church?         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  items       PlaylistItem[]
  radios      Radio[]
  schedules   RadioSchedule[]

  @@index([isAutoDJ, isActive])
  @@index([category])
  @@index([churchId])
}

model PlaylistItem {
  id         String   @id @default(cuid())
  title      String
  url        String
  type       String   @default("AUDIO")
  duration   Int?
  order      Int      @default(0)
  playlistId String
  createdAt  DateTime @default(now())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, order])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PrayerRequest {
  id          String           @id @default(cuid())
  userId      String
  title       String
  content     String
  category    String
  isUrgent    Boolean          @default(false)
  isAnswered  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  prayerChain PrayerChain?
  reactions   PrayerReaction[]
  user        User             @relation(fields: [userId], references: [id])
  responses   PrayerResponse[]
  testimony   PrayerTestimony?
  verses      PrayerVerse[]

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([isUrgent, createdAt])
  @@index([isAnswered, createdAt])
}

model PrayerResponse {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  content         String
  type            String        @default("COMMENT")
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@index([prayerRequestId, createdAt])
  @@index([userId])
}

model PrayerReaction {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  type            String
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@unique([userId, prayerRequestId, type])
  @@index([prayerRequestId, type])
}

model PrayerVerse {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  reference       String
  text            String?
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@index([prayerRequestId])
  @@index([userId])
}

model PrayerTestimony {
  id              String        @id @default(cuid())
  prayerRequestId String        @unique
  userId          String
  content         String
  imageUrl        String?
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([createdAt])
}

model PrayerChain {
  id              String            @id @default(cuid())
  prayerRequestId String?           @unique
  title           String
  description     String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  prayerRequest   PrayerRequest?    @relation(fields: [prayerRequestId], references: [id])
  links           PrayerChainLink[]

  @@index([isActive, createdAt])
}

model PrayerChainLink {
  id        String      @id @default(cuid())
  chainId   String
  userId    String
  message   String?
  createdAt DateTime    @default(now())
  chain     PrayerChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([chainId, userId])
  @@index([chainId, createdAt])
  @@index([userId])
}

model PrayerLiveRoom {
  id           String                  @id @default(cuid())
  title        String
  description  String?
  isPublic     Boolean                 @default(true)
  isActive     Boolean                 @default(true)
  moderatorId  String
  createdAt    DateTime                @default(now())
  endedAt      DateTime?
  participants PrayerRoomParticipant[]

  @@index([isActive, createdAt])
  @@index([isPublic, isActive])
}

model PrayerRoomParticipant {
  id            String         @id @default(cuid())
  roomId        String
  userId        String
  isMuted       Boolean        @default(true)
  hasHandRaised Boolean        @default(false)
  joinedAt      DateTime       @default(now())
  room          PrayerLiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([roomId, joinedAt])
}

model AudioTrack {
  id         String   @id @default(cuid())
  title      String
  artist     String?
  album      String?
  url        String
  coverUrl   String?
  duration   Int      @default(0)
  type       String   @default("MUSIC")
  category   String   @default("GENERAL")
  playCount  Int      @default(0)
  isActive   Boolean  @default(true)
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type, category])
  @@index([isActive, createdAt])
  @@index([playCount])
}

model RadioSchedule {
  id          String    @id @default(cuid())
  radioId     String
  playlistId  String?
  title       String
  description String?
  hostName    String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int       @default(60)
  isRecurring Boolean   @default(false)
  recurrence  String?
  isLive      Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  playlist    Playlist? @relation(fields: [playlistId], references: [id])
  radio       Radio     @relation(fields: [radioId], references: [id], onDelete: Cascade)

  @@index([radioId, startTime])
  @@index([isActive, startTime])
  @@index([isLive])
}

model RadioChatMessage {
  id        String   @id @default(cuid())
  radioId   String
  userId    String?
  name      String?
  content   String
  isPinned  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  radio     Radio    @relation(fields: [radioId], references: [id], onDelete: Cascade)

  @@index([radioId, createdAt])
  @@index([isPinned])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("ReceivedFriendships", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentFriendships", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId, status])
  @@index([receiverId, status])
  @@index([status, createdAt])
}

model Report {
  id          String    @id @default(cuid())
  reporterId  String
  targetId    String
  targetType  String
  reason      String
  description String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  reporter    User      @relation("ReportedItems", fields: [reporterId], references: [id])

  @@index([targetType, status])
  @@index([status, createdAt])
  @@index([reporterId, createdAt])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String?
  targetType String?
  details    Json?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, createdAt])
}

model PreachingCategory {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String?
  icon        String?
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  preachings  Preaching[]

  @@index([order])
}

model PreachingSeries {
  id          String      @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  authorId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  preachings  Preaching[]
  author      User        @relation("PreachingSeries", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId, createdAt])
}

model Preaching {
  id             String              @id @default(cuid())
  title          String
  description    String
  thumbnail      String
  videoUrl       String
  duration       Int
  views          Int                 @default(0)
  authorId       String
  categoryId     String
  seriesId       String?
  publishedAt    DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  author         User                @relation("Preachings", fields: [authorId], references: [id], onDelete: Cascade)
  category       PreachingCategory   @relation(fields: [categoryId], references: [id])
  series         PreachingSeries?    @relation(fields: [seriesId], references: [id])
  bookmarks      PreachingBookmark[]
  comments       PreachingComment[]
  likes          PreachingLike[]
  notes          PreachingNote[]
  verses         PreachingVerse[]
  preachingViews PreachingView[]

  @@index([authorId, publishedAt])
  @@index([categoryId, publishedAt])
  @@index([seriesId, publishedAt])
  @@index([publishedAt])
  @@index([views])
}

model PreachingView {
  id          String    @id @default(cuid())
  preachingId String
  userId      String
  watchedAt   DateTime  @default(now())
  duration    Int?
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User      @relation("PreachingViews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([preachingId, watchedAt])
  @@index([userId, watchedAt])
}

model PreachingLike {
  id          String    @id @default(cuid())
  preachingId String
  userId      String
  createdAt   DateTime  @default(now())
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User      @relation("PreachingLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([preachingId])
  @@index([userId])
}

model PreachingComment {
  id          String             @id @default(cuid())
  preachingId String
  userId      String
  content     String
  parentId    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  parent      PreachingComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     PreachingComment[] @relation("CommentReplies")
  preaching   Preaching          @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User               @relation("PreachingComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([preachingId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId])
}

model PreachingBookmark {
  id          String    @id @default(cuid())
  preachingId String
  userId      String
  createdAt   DateTime  @default(now())
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User      @relation("PreachingBookmarks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([preachingId])
  @@index([userId, createdAt])
}

model PreachingNote {
  id          String    @id @default(cuid())
  preachingId String
  userId      String
  content     String
  timestamp   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User      @relation("PreachingNotes", fields: [userId], references: [id], onDelete: Cascade)

  @@index([preachingId, userId])
  @@index([userId, createdAt])
}

model PreachingVerse {
  id          String    @id @default(cuid())
  preachingId String
  book        String
  chapter     Int
  verse       String
  text        String
  createdAt   DateTime  @default(now())
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)

  @@index([preachingId])
  @@index([book, chapter])
}

model LiveBroadcast {
  id          String    @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  streamUrl   String
  authorId    String
  viewerCount Int       @default(0)
  status      String    @default("SCHEDULED")
  scheduledAt DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation("LiveBroadcasts", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId, status])
  @@index([status, scheduledAt])
  @@index([status, startedAt])
}

model Church {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String?
  slogan          String?
  logo            String?
  coverImage      String?
  website         String?
  email           String?
  phone           String?
  address         String?
  city            String?
  country         String?
  isVerified      Boolean        @default(false)
  memberCount     Int            @default(0)
  followerCount   Int            @default(0)
  viewCount       Int            @default(0)
  donationEnabled Boolean        @default(false)
  radioEnabled    Boolean        @default(false)
  liveEnabled     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  schedule        Json[]         @default([])
  admins          ChurchAdmin[]
  courses         ChurchCourse[]
  events          ChurchEvent[]
  followers       ChurchFollow[]
  lives           ChurchLive[]
  media           ChurchMedia[]
  members         ChurchMember[]
  posts           ChurchPost[]
  radios          ChurchRadio[]
  playlists       Playlist[]

  @@index([slug])
  @@index([isVerified])
  @@index([city])
  @@index([country])
}

model ChurchMember {
  id       String   @id @default(cuid())
  churchId String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  isActive Boolean  @default(true)
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
  @@index([churchId, role])
  @@index([userId])
}

model ChurchAdmin {
  id          String   @id @default(cuid())
  churchId    String
  userId      String
  role        String   @default("CHURCH_ADMIN")
  appointedAt DateTime @default(now())
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
  @@index([churchId, role])
  @@index([userId])
}

model ChurchEvent {
  id            String                @id @default(cuid())
  churchId      String
  title         String
  description   String?
  imageUrl      String?
  startDate     DateTime
  endDate       DateTime?
  location      String?
  isPublic      Boolean               @default(true)
  attendeeCount Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  church        Church                @relation(fields: [churchId], references: [id], onDelete: Cascade)
  attendees     ChurchEventAttendee[]

  @@index([churchId, startDate])
  @@index([startDate])
  @@index([isPublic])
}

model ChurchEventAttendee {
  id       String      @id @default(cuid())
  eventId  String
  userId   String
  joinedAt DateTime    @default(now())
  event    ChurchEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model ChurchMedia {
  id        String   @id @default(cuid())
  churchId  String
  type      String   @default("IMAGE")
  title     String?
  url       String
  thumbnail String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId, type])
  @@index([churchId, order])
}

model ChurchRadio {
  id        String   @id @default(cuid())
  churchId  String
  radioId   String?
  name      String
  streamUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@index([isActive])
}

model ChurchLive {
  id              String    @id @default(cuid())
  churchId        String
  liveBroadcastId String?
  title           String
  streamUrl       String?   // RTMP URL pour envoi via OBS
  playUrl         String?   // URL de lecture pour iframe (YouTube embed, Twitch player, etc.)
  streamMode      String    @default("RTMP") // "RTMP" ou "WEBRTC"
  thumbnail       String?
  status          String    @default("OFFLINE")
  viewerCount     Int       @default(0)
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  church          Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId, status])
  @@index([status])
}

model ChurchCourse {
  id          String                   @id @default(cuid())
  churchId    String
  title       String
  description String?
  instructor  String?
  thumbnail   String?
  duration    Int?
  level       String                   @default("BEGINNER")
  category    String?
  isPublished Boolean                  @default(false)
  enrollCount Int                      @default(0)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  church      Church                   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  enrollments ChurchCourseEnrollment[]

  @@index([churchId, isPublished])
  @@index([level])
  @@index([category])
}

model ChurchCourseEnrollment {
  id          String       @id @default(cuid())
  courseId    String
  userId      String
  progress    Int          @default(0)
  completed   Boolean      @default(false)
  enrolledAt  DateTime     @default(now())
  completedAt DateTime?
  course      ChurchCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model ChurchPost {
  id        String              @id @default(cuid())
  churchId  String
  content   String?
  imageUrl  String?
  videoUrl  String?
  isPinned  Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  church    Church              @relation(fields: [churchId], references: [id], onDelete: Cascade)
  comments  ChurchPostComment[]
  likes     ChurchPostLike[]

  @@index([churchId, createdAt])
  @@index([isPinned])
}

model ChurchPostLike {
  id           String     @id @default(cuid())
  churchPostId String
  userId       String
  createdAt    DateTime   @default(now())
  churchPost   ChurchPost @relation(fields: [churchPostId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchPostId, userId])
  @@index([churchPostId])
  @@index([userId])
}

model ChurchPostComment {
  id           String              @id @default(cuid())
  churchPostId String
  userId       String
  content      String
  parentId     String?
  createdAt    DateTime            @default(now())
  churchPost   ChurchPost          @relation(fields: [churchPostId], references: [id], onDelete: Cascade)
  parent       ChurchPostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      ChurchPostComment[] @relation("CommentReplies")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([churchPostId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId])
}

model ChurchFollow {
  id        String   @id @default(cuid())
  churchId  String
  userId    String
  createdAt DateTime @default(now())
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
  @@index([churchId])
  @@index([userId])
}
