generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                      @id @default(cuid())
  email                      String                      @unique
  password                   String
  createdAt                  DateTime                    @default(now())
  image                      String?
  name                       String?
  bio                        String?
  role                       String                      @default("USER")
  city                       String?
  isBanned                   Boolean                     @default(false)
  isSuspended                Boolean                     @default(false)
  suspendedAt                DateTime?
  churchId                   String?
  accounts                   Account[]
  adminLogs                  AdminLog[]
  audioTracks                AudioTrack[]
  chatMemberships            ChatMember[]
  churchAdmins               ChurchAdmin[]
  churchCourseEnrollments    ChurchCourseEnrollment[]
  churchEventAttendees       ChurchEventAttendee[]
  churchFollows              ChurchFollow[]
  churchMemberships          ChurchMember[]
  churchPostComments         ChurchPostComment[]
  churchPostLikes            ChurchPostLike[]
  comments                   Comment[]
  friendships2               Friendship[]                @relation("FriendshipReceiver")
  friendships1               Friendship[]                @relation("FriendshipSender")
  likes                      Like[]
  sentMessages               Message[]                   @relation("MessageSender")
  messageSeen                MessageSeen[]
  notificationsSent          Notification[]              @relation("NotificationSender")
  notificationsReceived      Notification[]              @relation("NotificationReceiver")
  posts                      Post[]
  prayerChainLinks           PrayerChainLink[]
  prayerLiveParticipants     PrayerLiveParticipant[]
  PrayerLiveRoom             PrayerLiveRoom[]
  prayerLiveRoomMembers      PrayerLiveRoomMember[]
  prayerLiveRoomParticipants PrayerLiveRoomParticipant[]
  prayerReactions            PrayerReaction[]
  prayerRequests             PrayerRequest[]
  prayerResponses            PrayerResponse[]
  prayerTestimonies          PrayerTestimony[]
  prayerVerses               PrayerVerse[]
  preachings                 Preaching[]
  preachingBookmarks         PreachingBookmark[]
  preachingComments          PreachingComment[]
  preachingLikes             PreachingLike[]
  preachingNotes             PreachingNote[]
  preachingSeries            PreachingSeries[]
  preachingVerses            PreachingVerse[]
  preachingViews             PreachingView[]
  pushSubscriptions          PushSubscription[]
  radios                     Radio[]
  RadioChatMessage           RadioChatMessage[]
  refreshTokens              RefreshToken[]
  reportsCreated             Report[]                    @relation("ReportReporter")
  reportsResolved            Report[]                    @relation("ReportResolver")
  sessions                   Session[]
  shares                     Share[]
  stories                    Story[]
  storyViews                 StoryView[]
  streams                    Stream[]
  church                     Church?                     @relation("UserChurch", fields: [churchId], references: [id])
  followers                  UserFollow[]                @relation("UserFollowFollower")
  following                  UserFollow[]                @relation("UserFollowFollowing")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Post {
  id            String    @id @default(cuid())
  content       String?
  createdAt     DateTime  @default(now())
  authorId      String
  hashtags      String[]  @default([])
  imageUrl      String?
  videoUrl      String?
  isHidden      Boolean   @default(false)
  likes         Int       @default(0)
  comments      Comment[]
  likeRelations Like[]    @relation("PostLikes")
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  shares        Share[]

  @@index([createdAt])
  @@index([authorId, createdAt])
  @@index([isHidden])
  @@index([likes])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime  @default(now())
  parentId  String?
  isHidden  Boolean   @default(false)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation("PostLikes", fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Share {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Story {
  id        String      @id @default(cuid())
  imageUrl  String?
  videoUrl  String?
  content   String?
  createdAt DateTime    @default(now())
  expiresAt DateTime
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views     StoryView[]
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
}

model Chat {
  id        String       @id @default(cuid())
  isGroup   Boolean      @default(false)
  name      String?
  createdAt DateTime     @default(now())
  members   ChatMember[]
  messages  Message[]
}

model ChatMember {
  id       String    @id @default(cuid())
  userId   String
  chatId   String
  isTyping Boolean   @default(false)
  lastSeen DateTime?
  chat     Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
}

model Message {
  id        String        @id @default(cuid())
  content   String
  createdAt DateTime      @default(now())
  chatId    String
  senderId  String
  chat      Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  seen      MessageSeen[]
}

model MessageSeen {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  seenAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Notification {
  id         String   @id @default(cuid())
  type       String
  message    String
  userId     String
  createdAt  DateTime @default(now())
  senderId   String?
  entityId   String?
  entityType String?
  metadata   Json?
  read       Boolean  @default(false)
  sender     User?    @relation("NotificationSender", fields: [senderId], references: [id])
  user       User     @relation("NotificationReceiver", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([senderId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  createdAt DateTime @default(now())
  keys      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Report {
  id          String    @id @default(cuid())
  reporterId  String
  targetId    String
  targetType  String
  reason      String
  description String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  updatedAt   DateTime  @updatedAt
  reporter    User      @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver    User?     @relation("ReportResolver", fields: [resolvedBy], references: [id])

  @@index([reporterId])
  @@index([targetId])
  @@index([targetType])
  @@index([status])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   String?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model PreachingCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  icon        String?
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  banner      String?
  color       String?
  isActive    Boolean           @default(true)
  preachings  Preaching[]
  series      PreachingSeries[]

  @@index([order])
  @@index([isActive])
  @@index([name])
  @@index([slug])
}

model PreachingSeries {
  id          String             @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  authorId    String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  banner      String?
  categoryId  String?
  isFeatured  Boolean            @default(false)
  isPublished Boolean            @default(false)
  order       Int                @default(0)
  publishedAt DateTime?
  slug        String             @unique
  preachings  Preaching[]
  author      User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category    PreachingCategory? @relation(fields: [categoryId], references: [id])

  @@index([authorId])
  @@index([categoryId])
  @@index([slug])
  @@index([order])
  @@index([isFeatured])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([categoryId, order])
  @@index([categoryId, isPublished])
}

model Preaching {
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  id             String              @id @default(cuid())
  title          String
  description    String
  thumbnail      String?
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  videoUrl       String
  duration       Int?
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  authorId       String
  categoryId     String?
  seriesId       String?
  publishedAt    DateTime?
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  allowComments  Boolean             @default(true)
  allowDownload  Boolean             @default(false)
  allowSharing   Boolean             @default(true)
  audioUrl       String?
  banner         String?
  bookmarkCount  Int                 @default(0)
  commentCount   Int                 @default(0)
  isFeatured     Boolean             @default(false)
  isPinned       Boolean             @default(false)
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  isPublished    Boolean             @default(false)
  language       String              @default("fr")
  likeCount      Int                 @default(0)
  seoDescription String?
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  seoTitle       String?
  shareCount     Int                 @default(0)
  slug           String              @unique
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  tags           String[]            @default([])
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  viewCount      Int                 @default(0)
  /// /////////////////////////////////////////////////////////
  /// /////////////////////////////////////////////////////////
  visibility     String              @default("PUBLIC")
  author         User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category       PreachingCategory?  @relation(fields: [categoryId], references: [id])
  series         PreachingSeries?    @relation(fields: [seriesId], references: [id])
  bookmarks      PreachingBookmark[]
  comments       PreachingComment[]
  likes          PreachingLike[]
  notes          PreachingNote[]
  verses         PreachingVerse[]
  preachingViews PreachingView[]

  @@index([slug])
  @@index([authorId])
  @@index([categoryId])
  @@index([seriesId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([publishedAt])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([visibility])
  @@index([language])
  @@index([viewCount])
  @@index([likeCount])
  @@index([commentCount])
  @@index([bookmarkCount])
  @@index([authorId, createdAt])
  @@index([categoryId, publishedAt])
  @@index([seriesId, publishedAt])
  @@index([isPublished, publishedAt])
  @@index([isFeatured, publishedAt])
}

model PreachingView {
  id            String    @id @default(cuid())
  preachingId   String
  userId        String
  watchedAt     DateTime  @default(now())
  completed     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  device        String?
  ipAddress     String?
  platform      String?
  watchDuration Int?
  watchPercent  Float?
  preaching     Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([userId])
  @@index([preachingId])
  @@index([watchedAt])
  @@index([completed])
}

model PreachingLike {
  id          String    @id @default(cuid())
  preachingId String
  userId      String
  createdAt   DateTime  @default(now())
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([userId])
  @@index([preachingId])
}

model PreachingComment {
  id          String             @id @default(cuid())
  preachingId String
  userId      String
  content     String
  parentId    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  isEdited    Boolean            @default(false)
  isHidden    Boolean            @default(false)
  likeCount   Int                @default(0)
  replyCount  Int                @default(0)
  parent      PreachingComment?  @relation("PreachingCommentReplies", fields: [parentId], references: [id])
  replies     PreachingComment[] @relation("PreachingCommentReplies")
  preaching   Preaching          @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([preachingId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

model PreachingBookmark {
  id          String    @id @default(cuid())
  preachingId String
  userId      String
  createdAt   DateTime  @default(now())
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([userId])
  @@index([preachingId])
}

model PreachingNote {
  id          String    @id @default(cuid())
  preachingId String
  userId      String
  content     String
  timestamp   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  color       String?
  title       String?
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([preachingId])
}

model PreachingVerse {
  id          String    @id @default(cuid())
  preachingId String
  book        String
  chapter     Int
  text        String
  createdAt   DateTime  @default(now())
  reference   String
  translation String?
  userId      String
  verseEnd    Int?
  verseStart  Int
  preaching   Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([preachingId])
  @@index([userId])
  @@index([reference])
}

model LiveBroadcast {
  id          String       @id @default(cuid())
  title       String
  description String?
  streamUrl   String?
  status      String       @default("OFFLINE")
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime     @default(now())
  rtmpUrl     String?
  streamMode  String       @default("RTMP")
  webrtcUrl   String?
  churchLives ChurchLive[]
}

model Church {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  description     String?
  slogan          String?
  logo            String?
  coverImage      String?
  website         String?
  email           String?
  phone           String?
  address         String?
  city            String?
  country         String?
  donationEnabled Boolean          @default(false)
  radioEnabled    Boolean          @default(false)
  createdAt       DateTime         @default(now())
  schedule        String?
  admins          ChurchAdmin[]
  courses         ChurchCourse[]
  events          ChurchEvent[]
  follows         ChurchFollow[]
  lives           ChurchLive[]
  media           ChurchMedia[]
  members         ChurchMember[]
  playlists       ChurchPlaylist[]
  posts           ChurchPost[]
  radios          ChurchRadio[]
  users           User[]           @relation("UserChurch")
}

model ChurchMember {
  id       String   @id @default(cuid())
  churchId String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  isActive Boolean  @default(true)
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
}

model ChurchAdmin {
  id          String   @id @default(cuid())
  churchId    String
  userId      String
  role        String   @default("CHURCH_ADMIN")
  appointedAt DateTime @default(now())
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
}

model ChurchEvent {
  id            String                @id @default(cuid())
  churchId      String
  title         String
  description   String?
  imageUrl      String?
  startDate     DateTime
  endDate       DateTime?
  location      String?
  isPublic      Boolean               @default(true)
  attendeeCount Int                   @default(0)
  createdAt     DateTime              @default(now())
  church        Church                @relation(fields: [churchId], references: [id], onDelete: Cascade)
  attendees     ChurchEventAttendee[]
}

model ChurchEventAttendee {
  id        String      @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime    @default(now())
  status    String      @default("GOING")
  event     ChurchEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model ChurchMedia {
  id        String   @id @default(cuid())
  churchId  String
  type      String   @default("IMAGE")
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  caption   String?
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
}

model ChurchRadio {
  id          String          @id @default(cuid())
  churchId    String
  radioId     String?
  name        String?
  streamUrl   String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  description String?
  playlistId  String?
  schedule    String?
  title       String?
  church      Church          @relation(fields: [churchId], references: [id], onDelete: Cascade)
  playlist    ChurchPlaylist? @relation(fields: [playlistId], references: [id])
  radio       Radio?          @relation(fields: [radioId], references: [id])
}

model ChurchPlaylist {
  id          String               @id @default(cuid())
  churchId    String
  title       String
  description String?
  category    String               @default("GENERAL")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  church      Church               @relation(fields: [churchId], references: [id], onDelete: Cascade)
  items       ChurchPlaylistItem[]
  radios      ChurchRadio[]

  @@index([churchId])
}

model ChurchPlaylistItem {
  id         String         @id @default(cuid())
  playlistId String
  title      String
  url        String
  type       String         @default("AUDIO")
  mediaType  String         @default("AUDIO")
  artist     String?
  album      String?
  coverImage String?
  duration   Int?
  order      Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  playlist   ChurchPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@index([mediaType])
}

model ChurchLive {
  id              String         @id @default(cuid())
  churchId        String
  liveBroadcastId String?
  title           String?
  streamUrl       String?
  thumbnail       String?
  status          String         @default("SCHEDULED")
  viewerCount     Int            @default(0)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime       @default(now())
  description     String?
  playUrl         String?
  scheduledEnd    DateTime?
  scheduledStart  DateTime?
  streamMode      String?
  church          Church         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  broadcast       LiveBroadcast? @relation(fields: [liveBroadcastId], references: [id])
}

model ChurchCourse {
  id          String                   @id @default(cuid())
  churchId    String
  title       String
  description String?
  isPublished Boolean                  @default(false)
  enrollCount Int                      @default(0)
  createdAt   DateTime                 @default(now())
  imageUrl    String?
  church      Church                   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  enrollments ChurchCourseEnrollment[]
}

model ChurchCourseEnrollment {
  id        String       @id @default(cuid())
  courseId  String
  userId    String
  progress  Int          @default(0)
  createdAt DateTime     @default(now())
  course    ChurchCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model ChurchPost {
  id            String              @id @default(cuid())
  churchId      String
  content       String?
  imageUrl      String?
  videoUrl      String?
  createdAt     DateTime            @default(now())
  generated     Boolean             @default(false)
  generatedType String?
  generatedId   String?
  church        Church              @relation(fields: [churchId], references: [id], onDelete: Cascade)
  comments      ChurchPostComment[]
  likes         ChurchPostLike[]

  @@index([generatedType, generatedId])
}

model ChurchPostLike {
  id           String     @id @default(cuid())
  churchPostId String
  userId       String
  createdAt    DateTime   @default(now())
  post         ChurchPost @relation(fields: [churchPostId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchPostId, userId])
}

model ChurchPostComment {
  id           String     @id @default(cuid())
  churchPostId String
  userId       String
  content      String
  createdAt    DateTime   @default(now())
  post         ChurchPost @relation(fields: [churchPostId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChurchFollow {
  id        String   @id @default(cuid())
  churchId  String
  userId    String
  createdAt DateTime @default(now())
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
}

model Stream {
  id          String    @id @default(cuid())
  title       String
  description String?
  isLive      Boolean   @default(false)
  startedAt   DateTime?
  viewerCount Int       @default(0)
  userId      String?
  createdAt   DateTime  @default(now())
  status      String    @default("OFFLINE")
  streamUrl   String?
  user        User?     @relation(fields: [userId], references: [id])
}

model Radio {
  id            String             @id @default(cuid())
  title         String
  description   String?
  isLive        Boolean            @default(false)
  isAutoDJ      Boolean            @default(false)
  startedAt     DateTime?
  endedAt       DateTime?
  listenerCount Int                @default(0)
  peakListeners Int                @default(0)
  streamUrl     String?
  userId        String?
  playlistId    String?
  createdAt     DateTime           @default(now())
  currentTrack  String?
  status        String             @default("OFFLINE")
  churchRadios  ChurchRadio[]
  playlist      Playlist?          @relation(fields: [playlistId], references: [id])
  user          User?              @relation(fields: [userId], references: [id])
  chatMessages  RadioChatMessage[]
  schedules     RadioSchedule[]

  @@index([status])
  @@index([isLive])
}

model Playlist {
  id          String          @id @default(cuid())
  title       String
  description String?
  category    String          @default("GENERAL")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  items       PlaylistItem[]
  radios      Radio[]
  schedules   RadioSchedule[]
}

model PlaylistItem {
  id         String    @id @default(cuid())
  title      String
  url        String
  type       String    @default("AUDIO")
  duration   Int?
  order      Int       @default(0)
  playlistId String?
  createdAt  DateTime  @default(now())
  playlist   Playlist? @relation(fields: [playlistId], references: [id])
}

model PrayerRequest {
  id            String           @id @default(cuid())
  userId        String
  title         String
  content       String
  category      String?
  isUrgent      Boolean          @default(false)
  isAnswered    Boolean          @default(false)
  createdAt     DateTime         @default(now())
  prayerChainId String?
  reactions     PrayerReaction[]
  prayerChain   PrayerChain?     @relation(fields: [prayerChainId], references: [id])
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     PrayerResponse[]
  testimony     PrayerTestimony?
  verses        PrayerVerse[]
}

model PrayerLiveRoom {
  id                        String                      @id @default(cuid())
  title                     String
  description               String?
  isPublic                  Boolean                     @default(true)
  isActive                  Boolean                     @default(true)
  moderatorId               String
  createdAt                 DateTime                    @default(now())
  participants              PrayerLiveParticipant[]
  moderator                 User                        @relation(fields: [moderatorId], references: [id], onDelete: Cascade)
  PrayerLiveRoomMember      PrayerLiveRoomMember[]
  PrayerLiveRoomParticipant PrayerLiveRoomParticipant[]
}

model PrayerLiveParticipant {
  id       String         @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime       @default(now())
  room     PrayerLiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model PrayerLiveRoomMember {
  id       String         @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime       @default(now())
  room     PrayerLiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model PrayerLiveRoomParticipant {
  id       String         @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime       @default(now())
  room     PrayerLiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model PrayerChain {
  id              String            @id @default(cuid())
  prayerRequestId String?
  title           String
  description     String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  links           PrayerChainLink[]
  prayerRequests  PrayerRequest[]
}

model PrayerChainLink {
  id        String      @id @default(cuid())
  chainId   String
  userId    String
  message   String?
  createdAt DateTime    @default(now())
  chain     PrayerChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chainId, userId])
}

model PrayerReaction {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  type            String        @default("PRAY")
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, prayerRequestId, type])
}

model PrayerResponse {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  content         String
  type            String        @default("PRAYER")
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrayerVerse {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  reference       String
  text            String?
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([prayerRequestId])
  @@index([userId])
}

model PrayerTestimony {
  id              String        @id @default(cuid())
  prayerRequestId String        @unique
  userId          String
  content         String
  imageUrl        String?
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AudioTrack {
  id         String   @id @default(cuid())
  title      String
  artist     String?
  album      String?
  url        String
  coverUrl   String?
  duration   Int?
  type       String   @default("MUSIC")
  category   String?
  isActive   Boolean  @default(true)
  uploadedBy String?
  createdAt  DateTime @default(now())
  uploader   User?    @relation(fields: [uploadedBy], references: [id])
}

model RadioSchedule {
  id          String    @id @default(cuid())
  radioId     String
  playlistId  String?
  title       String
  description String?
  hostName    String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int       @default(60)
  isRecurring Boolean   @default(false)
  recurrence  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  playlist    Playlist? @relation(fields: [playlistId], references: [id])
  radio       Radio     @relation(fields: [radioId], references: [id], onDelete: Cascade)

  @@index([radioId])
  @@index([startTime])
}

model RadioChatMessage {
  id        String    @id @default(cuid())
  radioId   String
  userId    String?
  content   String
  isPinned  Boolean   @default(false)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  pinnedAt  DateTime?
  updatedAt DateTime  @updatedAt
  radio     Radio     @relation(fields: [radioId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([radioId])
  @@index([userId])
  @@index([createdAt])
}
