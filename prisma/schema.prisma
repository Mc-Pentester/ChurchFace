generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  createdAt   DateTime  @default(now())
  image       String?
  name        String?
  bio         String?
  church      String?
  city        String?
  role        String    @default("USER")
  isSuspended Boolean   @default(false)
  isBanned    Boolean   @default(false)
  suspendedAt DateTime?
  bannedAt    DateTime?

  pushSubscriptions PushSubscription[]

  accounts               Account[]
  chats                  ChatMember[]
  comments               Comment[]
  likes                  Like[]
  messages               Message[]
  messagesSeen           MessageSeen[]
  sentNotifications      Notification[]          @relation("Sender")
  notifications          Notification[]          @relation("Receiver")
  posts                  Post[]
  prayerRequests         PrayerRequest[]
  prayerResponses        PrayerResponse[]
  prayerReactions        PrayerReaction[]
  prayerVerses           PrayerVerse[]
  prayerTestimonies      PrayerTestimony[]
  prayerChainLinks       PrayerChainLink[]
  prayerRoomParticipants PrayerRoomParticipant[]
  radios                 Radio[]
  sessions               Session[]
  shares                 Share[]
  stories                Story[]
  storyViews             StoryView[]
  streams                Stream[]
  friendshipsSent        Friendship[]            @relation("SentFriendships")
  friendshipsReceived    Friendship[]            @relation("ReceivedFriendships")
  reports                Report[]                @relation("ReportedItems")
  adminLogs              AdminLog[]
  following              UserFollow[]            @relation("Following")
  followers              UserFollow[]            @relation("Followers")
  
  // Preaching System
  preachings          Preaching[] @relation("Preachings")
  preachingSeries     PreachingSeries[] @relation("PreachingSeries")
  preachingViews      PreachingView[] @relation("PreachingViews")
  preachingLikes      PreachingLike[] @relation("PreachingLikes")
  preachingComments   PreachingComment[] @relation("PreachingComments")
  preachingBookmarks  PreachingBookmark[] @relation("PreachingBookmarks")
  preachingNotes      PreachingNote[] @relation("PreachingNotes")
  liveBroadcasts      LiveBroadcast[] @relation("LiveBroadcasts")
  
  // Church System
  churchMembers       ChurchMember[]
  churchAdmins        ChurchAdmin[]
  churchEventAttendees ChurchEventAttendee[]
  churchCourseEnrollments ChurchCourseEnrollment[]
  churchPostLikes     ChurchPostLike[]
  churchPostComments  ChurchPostComment[]
  churchFollows       ChurchFollow[]
}

model Chat {
  id        String       @id @default(cuid())
  isGroup   Boolean      @default(false)
  name      String?
  createdAt DateTime     @default(now())
  members   ChatMember[]
  messages  Message[]
}

model ChatMember {
  id       String    @id @default(cuid())
  userId   String
  chatId   String
  isTyping Boolean   @default(false)
  lastSeen DateTime?
  chat     Chat      @relation(fields: [chatId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@unique([userId, chatId])
}

model Message {
  id        String        @id @default(cuid())
  content   String
  createdAt DateTime      @default(now())
  chatId    String
  senderId  String
  chat      Chat          @relation(fields: [chatId], references: [id])
  sender    User          @relation(fields: [senderId], references: [id])
  seenBy    MessageSeen[]
}

model MessageSeen {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  seenAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model Post {
  id        String    @id @default(cuid())
  content   String?
  createdAt DateTime  @default(now())
  authorId  String
  hashtags  String[]  @default([])
  imageUrl  String?
  videoUrl  String?
  isHidden  Boolean   @default(false)
  isPinned  Boolean   @default(false)
  comments  Comment[]
  likes     Like[]
  author    User      @relation(fields: [authorId], references: [id])
  shares    Share[]

  @@index([createdAt])
  @@index([authorId, createdAt])
  @@index([isHidden])
  @@index([isPinned])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model Share {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime  @default(now())
  parentId  String?
  isHidden  Boolean   @default(false)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  post      Post      @relation(fields: [postId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId])
  @@index([isHidden])
}

model Story {
  id        String      @id @default(cuid())
  imageUrl  String?
  videoUrl  String?
  content   String?
  createdAt DateTime    @default(now())
  expiresAt DateTime
  authorId  String
  isHidden  Boolean     @default(false)
  author    User        @relation(fields: [authorId], references: [id])
  views     StoryView[]

  @@index([expiresAt])
  @@index([authorId, createdAt])
  @@index([isHidden])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([storyId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  message   String
  isRead    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  senderId  String?
  sender    User?    @relation("Sender", fields: [senderId], references: [id])
  user      User     @relation("Receiver", fields: [userId], references: [id])

  entityId   String? // postId, commentId, etc.
  entityType String? // "post", "comment", "follow"
  data       Json? // flexible payload

  @@index([userId, isRead])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  createdAt   DateTime @default(now())
}

model Stream {
  id          String    @id @default(cuid())
  title       String
  description String?
  isLive      Boolean   @default(true)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  viewerCount Int       @default(0)
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  @@index([isLive, startedAt])
  @@index([userId])
}

model Radio {
  id             String             @id @default(cuid())
  title          String
  description    String?
  isLive         Boolean            @default(false)
  isAutoDJ       Boolean            @default(false)
  startedAt      DateTime           @default(now())
  endedAt        DateTime?
  listenerCount  Int                @default(0)
  peakListeners  Int                @default(0)
  totalDuration  Int                @default(0)
  streamUrl      String?
  rtmpUrl        String?
  currentTrackId String?
  userId         String
  playlistId     String?
  playlist       Playlist?          @relation(fields: [playlistId], references: [id])
  user           User               @relation(fields: [userId], references: [id])
  chatMessages   RadioChatMessage[]
  schedules      RadioSchedule[]

  @@index([isLive, startedAt])
  @@index([userId])
}

model Playlist {
  id          String          @id @default(cuid())
  title       String
  description String?
  isAutoDJ    Boolean         @default(false)
  category    String          @default("GENERAL")
  isActive    Boolean         @default(true)
  shuffle     Boolean         @default(false)
  loop        Boolean         @default(false)
  churchId    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  items       PlaylistItem[]
  radios      Radio[]
  schedules   RadioSchedule[]
  church      Church?         @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([isAutoDJ, isActive])
  @@index([category])
  @@index([churchId])
}

model PlaylistItem {
  id         String   @id @default(cuid())
  title      String
  url        String
  type       String   @default("AUDIO")
  duration   Int?
  order      Int      @default(0)
  playlistId String
  createdAt  DateTime @default(now())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, order])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── ESPACE DE PRIÈRE ───

model PrayerRequest {
  id          String           @id @default(cuid())
  userId      String
  title       String
  content     String
  category    String
  isUrgent    Boolean          @default(false)
  isAnswered  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id])
  responses   PrayerResponse[]
  reactions   PrayerReaction[]
  verses      PrayerVerse[]
  testimony   PrayerTestimony?
  prayerChain PrayerChain?

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([isUrgent, createdAt])
  @@index([isAnswered, createdAt])
}

model PrayerResponse {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  content         String
  type            String        @default("COMMENT")
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@index([prayerRequestId, createdAt])
  @@index([userId])
}

model PrayerReaction {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  type            String
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@unique([userId, prayerRequestId, type])
  @@index([prayerRequestId, type])
}

model PrayerVerse {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  reference       String
  text            String?
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@index([prayerRequestId])
  @@index([userId])
}

model PrayerTestimony {
  id              String        @id @default(cuid())
  prayerRequestId String        @unique
  userId          String
  content         String
  imageUrl        String?
  createdAt       DateTime      @default(now())
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([createdAt])
}

model PrayerChain {
  id              String            @id @default(cuid())
  prayerRequestId String?           @unique
  title           String
  description     String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  links           PrayerChainLink[]
  prayerRequest   PrayerRequest?    @relation(fields: [prayerRequestId], references: [id])

  @@index([isActive, createdAt])
}

model PrayerChainLink {
  id        String      @id @default(cuid())
  chainId   String
  userId    String
  message   String?
  createdAt DateTime    @default(now())
  chain     PrayerChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([chainId, userId])
  @@index([chainId, createdAt])
  @@index([userId])
}

model PrayerLiveRoom {
  id           String                  @id @default(cuid())
  title        String
  description  String?
  isPublic     Boolean                 @default(true)
  isActive     Boolean                 @default(true)
  moderatorId  String
  createdAt    DateTime                @default(now())
  endedAt      DateTime?
  participants PrayerRoomParticipant[]

  @@index([isActive, createdAt])
  @@index([isPublic, isActive])
}

model PrayerRoomParticipant {
  id            String         @id @default(cuid())
  roomId        String
  userId        String
  isMuted       Boolean        @default(true)
  hasHandRaised Boolean        @default(false)
  joinedAt      DateTime       @default(now())
  room          PrayerLiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([roomId, joinedAt])
}

// ─── STUDIO RADIO ───

model AudioTrack {
  id         String   @id @default(cuid())
  title      String
  artist     String?
  album      String?
  url        String
  coverUrl   String?
  duration   Int      @default(0)
  type       String   @default("MUSIC")
  category   String   @default("GENERAL")
  playCount  Int      @default(0)
  isActive   Boolean  @default(true)
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type, category])
  @@index([isActive, createdAt])
  @@index([playCount])
}

model RadioSchedule {
  id          String    @id @default(cuid())
  radioId     String
  playlistId  String?
  title       String
  description String?
  hostName    String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int       @default(60)
  isRecurring Boolean   @default(false)
  recurrence  String?
  isLive      Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  radio       Radio     @relation(fields: [radioId], references: [id], onDelete: Cascade)
  playlist    Playlist? @relation(fields: [playlistId], references: [id])

  @@index([radioId, startTime])
  @@index([isActive, startTime])
  @@index([isLive])
}

model RadioChatMessage {
  id        String   @id @default(cuid())
  radioId   String
  userId    String?
  name      String?
  content   String
  isPinned  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  radio     Radio    @relation(fields: [radioId], references: [id], onDelete: Cascade)

  @@index([radioId, createdAt])
  @@index([isPinned])
}

// ─── SYSTÈME D'AMIS ───

model UserFollow {
  id        String   @id @default(cuid())
  followerId String
  followingId String
  createdAt DateTime @default(now())

  follower  User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, DECLINED, BLOCKED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("SentFriendships", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriendships", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId, status])
  @@index([receiverId, status])
  @@index([status, createdAt])
}

// ─── SYSTÈME DE MODÉRATION ───

model Report {
  id          String    @id @default(cuid())
  reporterId  String
  targetId    String
  targetType  String // "post", "comment", "story", "user"
  reason      String // "spam", "harassment", "fake_account", "offensive", "inappropriate", "other"
  description String?
  status      String    @default("PENDING") // PENDING, RESOLVED, DISMISSED
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  reporter User @relation("ReportedItems", fields: [reporterId], references: [id])

  @@index([targetType, status])
  @@index([status, createdAt])
  @@index([reporterId, createdAt])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String // "approve_post", "hide_post", "delete_post", "restore_post", "pin_post", "suspend_user", "ban_user", "reactivate_user", "resolve_report", "dismiss_report"
  targetId   String?
  targetType String? // "post", "comment", "story", "user", "report"
  details    Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, createdAt])
}

// ─── ESPACE DE DIFFUSION (PRÉDICATIONS) ───

model PreachingCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  icon        String?    // emoji or icon name
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  preachings Preaching[]

  @@index([order])
}

model PreachingSeries {
  id          String     @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  authorId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  author     User       @relation("PreachingSeries", fields: [authorId], references: [id], onDelete: Cascade)
  preachings Preaching[]

  @@index([authorId, createdAt])
}

model Preaching {
  id          String   @id @default(cuid())
  title       String
  description String
  thumbnail   String
  videoUrl    String
  duration    Int      // in seconds
  views       Int      @default(0)
  authorId    String
  categoryId  String
  seriesId    String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author     User              @relation("Preachings", fields: [authorId], references: [id], onDelete: Cascade)
  category   PreachingCategory @relation(fields: [categoryId], references: [id])
  series     PreachingSeries?  @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  preachingViews PreachingView[]
  likes      PreachingLike[]
  comments   PreachingComment[]
  bookmarks  PreachingBookmark[]
  notes      PreachingNote[]
  verses     PreachingVerse[]

  @@index([authorId, publishedAt])
  @@index([categoryId, publishedAt])
  @@index([seriesId, publishedAt])
  @@index([publishedAt])
  @@index([views])
}

model PreachingView {
  id          String   @id @default(cuid())
  preachingId String
  userId      String
  watchedAt   DateTime @default(now())
  duration    Int?     // how much of the video was watched in seconds

  preaching Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user      User       @relation("PreachingViews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([preachingId, watchedAt])
  @@index([userId, watchedAt])
}

model PreachingLike {
  id          String   @id @default(cuid())
  preachingId String
  userId      String
  createdAt   DateTime @default(now())

  preaching Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user      User       @relation("PreachingLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([preachingId])
  @@index([userId])
}

model PreachingComment {
  id          String   @id @default(cuid())
  preachingId String
  userId      String
  content     String
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  preaching Preaching          @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user      User               @relation("PreachingComments", fields: [userId], references: [id], onDelete: Cascade)
  parent    PreachingComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   PreachingComment[] @relation("CommentReplies")

  @@index([preachingId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId])
}

model PreachingBookmark {
  id          String   @id @default(cuid())
  preachingId String
  userId      String
  createdAt   DateTime @default(now())

  preaching Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user      User       @relation("PreachingBookmarks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([preachingId, userId])
  @@index([preachingId])
  @@index([userId, createdAt])
}

model PreachingNote {
  id          String   @id @default(cuid())
  preachingId String
  userId      String
  content     String
  timestamp   Int?       // timestamp in the video where the note was taken
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  preaching Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)
  user      User       @relation("PreachingNotes", fields: [userId], references: [id], onDelete: Cascade)

  @@index([preachingId, userId])
  @@index([userId, createdAt])
}

model PreachingVerse {
  id          String   @id @default(cuid())
  preachingId String
  book        String    // e.g., "Jean", "Romains", "Psaume"
  chapter     Int
  verse       String    // e.g., "16", "28", "1-6"
  text        String
  createdAt   DateTime  @default(now())

  preaching Preaching @relation(fields: [preachingId], references: [id], onDelete: Cascade)

  @@index([preachingId])
  @@index([book, chapter])
}

model LiveBroadcast {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  streamUrl   String
  authorId    String
  viewerCount Int      @default(0)
  status      String   @default("SCHEDULED") // SCHEDULED, LIVE, ENDED
  scheduledAt DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation("LiveBroadcasts", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId, status])
  @@index([status, scheduledAt])
  @@index([status, startedAt])
}

// ─── SYSTÈME D'ÉGLISE ───

model Church {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  slogan          String?
  logo            String?
  coverImage      String?
  website         String?
  email           String?
  phone           String?
  address         String?
  city            String?
  country         String?
  isVerified      Boolean  @default(false)
  memberCount     Int      @default(0)
  followerCount   Int      @default(0)
  viewCount       Int      @default(0)
  donationEnabled Boolean  @default(false)
  radioEnabled    Boolean  @default(false)
  liveEnabled     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  members     ChurchMember[]
  admins      ChurchAdmin[]
  events      ChurchEvent[]
  media       ChurchMedia[]
  radios      ChurchRadio[]
  lives       ChurchLive[]
  courses     ChurchCourse[]
  posts       ChurchPost[]
  followers   ChurchFollow[]
  playlists   Playlist[]

  @@index([slug])
  @@index([isVerified])
  @@index([city])
  @@index([country])
}

model ChurchMember {
  id        String   @id @default(cuid())
  churchId  String
  userId    String
  role      String   @default("MEMBER") // MEMBER, ELDER, DEACON, YOUTH_LEADER, MUSICIAN
  joinedAt  DateTime @default(now())
  isActive  Boolean  @default(true)

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
  @@index([churchId, role])
  @@index([userId])
}

model ChurchAdmin {
  id        String   @id @default(cuid())
  churchId  String
  userId    String
  role      String   @default("CHURCH_ADMIN") // CHURCH_OWNER, CHURCH_ADMIN, CHURCH_MODERATOR, PASTOR, ASSOCIATE_PASTOR, RADIO_MANAGER, LIVE_MANAGER, COURSE_MANAGER
  appointedAt DateTime @default(now())

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
  @@index([churchId, role])
  @@index([userId])
}

model ChurchEvent {
  id          String   @id @default(cuid())
  churchId    String
  title       String
  description String?
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  isPublic    Boolean  @default(true)
  attendeeCount Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church   Church           @relation(fields: [churchId], references: [id], onDelete: Cascade)
  attendees ChurchEventAttendee[]

  @@index([churchId, startDate])
  @@index([startDate])
  @@index([isPublic])
}

model ChurchEventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  joinedAt  DateTime @default(now())

  event ChurchEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model ChurchMedia {
  id        String   @id @default(cuid())
  churchId  String
  type      String   @default("IMAGE") // IMAGE, VIDEO, ALBUM
  title     String?
  url       String
  thumbnail String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId, type])
  @@index([churchId, order])
}

model ChurchRadio {
  id        String   @id @default(cuid())
  churchId  String
  radioId   String?  // Link to existing Radio model
  name      String
  streamUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@index([isActive])
}

model ChurchLive {
  id           String   @id @default(cuid())
  churchId     String
  liveBroadcastId String? // Link to existing LiveBroadcast model
  title        String
  streamUrl    String?
  thumbnail    String?
  status       String   @default("OFFLINE") // OFFLINE, SCHEDULED, LIVE
  viewerCount  Int      @default(0)
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId, status])
  @@index([status])
}

model ChurchCourse {
  id          String   @id @default(cuid())
  churchId    String
  title       String
  description String?
  instructor  String?
  thumbnail   String?
  duration    Int?     // in minutes
  level       String   @default("BEGINNER") // BEGINNER, INTERMEDIATE, ADVANCED
  category    String?
  isPublished Boolean  @default(false)
  enrollCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church     Church           @relation(fields: [churchId], references: [id], onDelete: Cascade)
  enrollments ChurchCourseEnrollment[]

  @@index([churchId, isPublished])
  @@index([level])
  @@index([category])
}

model ChurchCourseEnrollment {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  progress  Int      @default(0) // percentage
  completed Boolean  @default(false)
  enrolledAt DateTime @default(now())
  completedAt DateTime?

  course ChurchCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model ChurchPost {
  id        String   @id @default(cuid())
  churchId  String
  content   String?
  imageUrl  String?
  videoUrl  String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church   Church          @relation(fields: [churchId], references: [id], onDelete: Cascade)
  likes    ChurchPostLike[]
  comments ChurchPostComment[]

  @@index([churchId, createdAt])
  @@index([isPinned])
}

model ChurchPostLike {
  id         String     @id @default(cuid())
  churchPostId String
  userId     String
  createdAt  DateTime @default(now())

  churchPost ChurchPost @relation(fields: [churchPostId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchPostId, userId])
  @@index([churchPostId])
  @@index([userId])
}

model ChurchPostComment {
  id          String     @id @default(cuid())
  churchPostId String
  userId      String
  content     String
  parentId    String?
  createdAt   DateTime @default(now())

  churchPost ChurchPost           @relation(fields: [churchPostId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     ChurchPostComment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ChurchPostComment[]  @relation("CommentReplies")

  @@index([churchPostId, createdAt])
  @@index([userId, createdAt])
  @@index([parentId])
}

model ChurchFollow {
  id        String   @id @default(cuid())
  churchId  String
  userId    String
  createdAt DateTime @default(now())

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
  @@index([churchId])
  @@index([userId])
}
