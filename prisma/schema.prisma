model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
